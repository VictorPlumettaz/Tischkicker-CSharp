@page "/live"
@layout EmptyLayout
@implements IDisposable
@inject IDbContextFactory<AppDbContext> Dbf
@inject TournamentSetup Setup
@inject MiraService Mira
@inject LiveNotifier Notifier
@inject SettingsService Cfg

<PageTitle>Tischkicker – Live</PageTitle>

<div class="live-root">
    <div class="ball animate-ball-roll">⚽</div>

    @if (_goalSide is not null)
    {
        <div class="goal-banner animate-goal-banner" @key="_goalKey"><span>TOOR!</span></div>
    }

    <header class="live-header">
        <img src="/assets/logos/A+W_invers_rgb.png" alt="A+W" />
        <span style="font-size:1.1rem; font-weight:600; opacity:0.8">@(_currentTournament?.Name ?? "Tischkicker-Turnier") · Sommerfest 2026</span>
    </header>

    <main class="live-main">
        <section class="live-center">
            @if (_champion is not null)
            {
                <div class="ceremony animate-goal-banner">
                    <div class="trophy animate-trophy">🏆</div>
                    <div class="title">Turniersieger</div>
                    <div class="winner">@Name(_champion.Value.WinnerId)</div>
                    @if (_champion.Value.RunnerId is { } r) { <div class="runner">2. Platz: <strong style="color:rgba(255,255,255,0.8)">@Name(r)</strong></div> }
                    <div style="margin-top:1.5rem; font-size:1.25rem; opacity:0.5">Herzlichen Glückwunsch! 🎉</div>
                </div>
            }
            else if (_current is { } m)
            {
                var half = _currentTournament?.HalfDurationSec ?? 360;
                var halves = _currentTournament?.Halves ?? 1;
                var remaining = MatchClock.RemainingSeconds(new ClockState(m.ElapsedSec, m.TimerRunning, m.TimerStartedAtMs), half, MatchControl.NowMs());
                <div style="font-size:1.5rem; opacity:0.7; margin-bottom:1rem">@(halves > 1 ? $"Halbzeit {m.CurrentHalf}/{halves}" : "Spiel läuft")</div>
                <div class="scoreline">
                    <div class="team">
                        <div class="team-name">@Name(m.TeamAId)</div>
                        <div class="team-score @(_goalSide == "a" ? "animate-goal-pop" : "")" @key="@("a" + _goalKey)">@m.ScoreA</div>
                    </div>
                    <div style="display:flex; flex-direction:column; align-items:center">
                        <div class="clock @(remaining <= 0 ? "over" : m.TimerRunning ? "running" : "paused")">@FormatClock(remaining)</div>
                        <div style="margin-top:0.5rem; opacity:0.5">@(m.TimerRunning ? (remaining <= 0 ? "Zeit!" : "") : "Pause")</div>
                    </div>
                    <div class="team">
                        <div class="team-name">@Name(m.TeamBId)</div>
                        <div class="team-score @(_goalSide == "b" ? "animate-goal-pop" : "")" @key="@("b" + _goalKey)">@m.ScoreB</div>
                    </div>
                </div>
            }
            else
            {
                var plan = _activeTid is { } tid2 ? _matches.Where(m => m.TournamentId == tid2).ToList() : [];
                if (plan.Count == 0)
                {
                    <div style="text-align:center">
                        <div style="font-size:3rem; font-weight:700; opacity:0.8">Bereit für den Anpfiff</div>
                        @if (_next is { } n) { <div style="font-size:1.75rem; opacity:0.6; margin-top:1rem">@Name(n.TeamAId) vs. @Name(n.TeamBId)</div> }
                    </div>
                }
                else
                {
                    <div class="idle-wrap">
                        <div class="idle-hint">Spielplan ⚽</div>
                        <div class="plan">
                            @foreach (var sec in BuildPlan(plan))
                            {
                                @if (sec.Header is not null) { <h4>@sec.Header</h4> }
                                @foreach (var pm in sec.Rows)
                                {
                                    var done = pm.Status == MatchStatus.Finished;
                                    <div class="plan-row @(done ? "done" : "") @(pm.Id == _next?.Id ? "next" : "")">
                                        <span class="pl-team">@Name(pm.TeamAId)</span>
                                        <span class="pl-score">@(done ? $"{pm.ScoreA}:{pm.ScoreB}" : "–")</span>
                                        <span class="pl-team r">@Name(pm.TeamBId)</span>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            }
        </section>

        <aside class="live-side">
            @{ var groups = _standings?.Groups.Where(g => g.Rows.Count > 0).ToList() ?? []; }
            @if (groups.Count > 0)
            {
                <div class="side-title">Live-Tabelle</div>
                @foreach (var g in groups)
                {
                    <div class="live-table">
                        @if (g.GroupName is not null) { <h3>Gruppe @g.GroupName</h3> }
                        <table>
                            <thead><tr><th class="l">#</th><th class="l">Team</th><th>Sp</th><th>Diff</th><th>Pkt</th></tr></thead>
                            <tbody>
                            @{ var i = 1; }
                            @foreach (var row in g.Rows)
                            {
                                <tr class="@(_currentIds.Contains(row.TeamId) ? "hl" : "")">
                                    <td class="l" style="opacity:0.4">@(i++)</td>
                                    <td class="l">@Name(row.TeamId)</td>
                                    <td style="opacity:0.6">@row.Played</td>
                                    <td style="opacity:0.6">@(row.GoalDiff > 0 ? "+" + row.GoalDiff : row.GoalDiff)</td>
                                    <td style="font-weight:700">@row.Points</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            }
            else if (_upcoming.Count > 0)
            {
                <div class="side-title">Kommende Spiele</div>
                <div class="live-table">
                    @foreach (var u in _upcoming)
                    {
                        <div style="display:flex; justify-content:space-between; gap:0.5rem; padding:0.25rem 0">
                            <span>@Name(u.TeamAId)</span><span style="opacity:0.4">vs.</span><span>@Name(u.TeamBId)</span>
                        </div>
                    }
                </div>
            }
        </aside>
    </main>

    <footer class="live-footer">
        <div style="font-size:1.25rem; opacity:0.8">
            @if (_next is { } n2) { <span>Als Nächstes: <strong>@Name(n2.TeamAId) vs. @Name(n2.TeamBId)</strong></span> }
            else { <span style="opacity:0.5">Kein weiteres Spiel geplant</span> }
        </div>
        <div style="display:flex; align-items:flex-end; gap:1rem">
            <div class="mira-bubble">@(_miraText.Length > 0 ? _miraText : "Willkommen beim A+W Tischkicker-Turnier! 🏆")</div>
            <img class="mira-img" src="@(_current is not null ? "/assets/mira/Mira_unterwegs.png" : "/assets/mira/Mira_standing.png")" alt="MIRA" />
        </div>
    </footer>
</div>

@code {
    private List<Match> _matches = [];
    private Dictionary<int, string> _names = new();
    private List<Tournament> _tournaments = [];
    private StandingsResponse? _standings;
    private Match? _current, _next;
    private Tournament? _currentTournament;
    private int? _activeTid;
    private HashSet<int> _currentIds = [];
    private List<Match> _upcoming = [];
    private (int WinnerId, int? RunnerId)? _champion;

    private string _miraText = "";
    private Match? _prevForMira;
    private bool _miraBusy;
    private (int Id, int A, int B)? _prevScore;
    private string? _goalSide;
    private int _goalKey;

    // Rückstands-Historie des laufenden Spiels: lag ein Team schon mal hinten? (für „Spiel gedreht")
    private int _behindMatchId;
    private bool _aWasBehind, _bWasBehind;

    // Merkt, für welches Turnier der K.o.-Start bereits angesagt wurde (einmalig pro Turnier).
    private int _koAnnouncedTid;
    // Merkt, für welches Turnier der Turniersieger bereits gefeiert wurde (einmalig pro Turnier).
    private int _championAnnouncedTid;

    // Zeit-Trigger-Zustand (pro laufendem Spiel).
    // Abstand periodischer Zwischenkommentare – aus den MIRA-Settings, bei jedem Reload aufgefrischt.
    private long _interludeIntervalMs = SettingsService.DefaultInterludeSec * 1000L;
    private int _timeMatchId;
    private int _finalMinuteHalf;
    private bool _goldenGoalAnnounced;
    private bool _timeUpAnnounced;
    private long _lastInterludeMs;

    private System.Threading.Timer? _clock;
    private System.Threading.Timer? _goalClear;

    protected override async Task OnInitializedAsync()
    {
        Notifier.Changed += OnChanged;
        await Reload();
        // Ticker: rendert die Uhr weiter UND prüft zeitbezogene MIRA-Anlässe.
        _clock = new System.Threading.Timer(_ => InvokeAsync(Tick), null, 250, 250);
    }

    private void OnChanged() => _ = InvokeAsync(Reload);

    /// <summary>Läuft alle 250 ms: Uhr neu rendern + zeitbezogene MIRA-Kommentare auslösen.</summary>
    private async Task Tick()
    {
        if (!_miraBusy && DetectTimeContext() is { } ctx) await EmitMira(ctx);
        StateHasChanged();
    }

    private async Task Reload()
    {
        _interludeIntervalMs = Cfg.GetMiraConfigPublic().InterludeSec * 1000L;

        await using var db = await Dbf.CreateDbContextAsync();
        _matches = await db.Matches.ToListAsync();
        _tournaments = await db.Tournaments.OrderByDescending(t => t.CreatedAt).ToListAsync();
        _names = await db.Teams.ToDictionaryAsync(t => t.Id, t => t.Name);

        _current = _matches.FirstOrDefault(m => m.Status == MatchStatus.Live);
        _next = _matches.Where(m => m.Status == MatchStatus.Scheduled)
            .OrderBy(m => m.Round ?? 0).ThenBy(m => m.Id)
            .FirstOrDefault(m => m.TeamAId is not null && m.TeamBId is not null)
            ?? _matches.Where(m => m.Status == MatchStatus.Scheduled).OrderBy(m => m.Round ?? 0).ThenBy(m => m.Id).FirstOrDefault();

        var activeTid = _current?.TournamentId ?? _next?.TournamentId
            ?? _tournaments.FirstOrDefault(t => _matches.Any(m => m.TournamentId == t.Id))?.Id;
        _activeTid = activeTid;
        _currentTournament = _tournaments.FirstOrDefault(t => t.Id == activeTid);
        // Live-Tabelle: laufendes Spiel wird mit seinem Zwischenstand provisorisch mitgerechnet.
        _standings = activeTid is { } tid ? Setup.GetStandings(tid, includeLive: true) : null;

        _currentIds = new HashSet<int>(new[] { _current?.TeamAId, _current?.TeamBId }.Where(x => x is not null).Select(x => x!.Value));
        _upcoming = _matches.Where(m => m.Status == MatchStatus.Scheduled && m.Id != _current?.Id).Take(8).ToList();

        _champion = ComputeChampion(activeTid);

        // Tor-Animation sofort auslösen – vor dem evtl. langsamen KI-Aufruf.
        DetectGoal(_current);

        // Tabelle + Spielstand SOFORT pushen, unabhängig vom evtl. langsamen MIRA-Aufruf.
        StateHasChanged();

        // Rückstands-Historie bei Spielwechsel zurücksetzen (Flags spiegeln den Verlauf bis _prevForMira).
        if (_current is { } cm && _behindMatchId != cm.Id)
        {
            _behindMatchId = cm.Id;
            _aWasBehind = _bWasBehind = false;
        }

        // MIRA-Kommentar bei Spielübergängen (Tor, Anpfiff, Halbzeit, Ende …).
        var ctx = MiraNarrator.Derive(_prevForMira, _current, _next, Name, _aWasBehind, _bWasBehind);
        // Gerade automatisch erzeugte K.o.-Phase hat Vorrang vor der normalen Ankündigung.
        if (_current is null && DetectKnockoutStart() is { } koCtx) ctx = koCtx;
        // Turniersieger feiern (einmalig, hat höchste Priorität zur Siegerehrung).
        if (_champion is { } champ && _activeTid is { } champTid && _championAnnouncedTid != champTid)
        {
            _championAnnouncedTid = champTid;
            ctx = new MiraContext
            {
                Mood = MiraMood.Champion,
                Scorer = Name(champ.WinnerId),
                Other = champ.RunnerId is { } r ? Name(r) : null,
            };
        }
        _prevForMira = _current;

        // Rückstands-Historie mit dem aktuellen Stand fortschreiben (nach dem Ableiten).
        if (_current is { } cur)
        {
            if (cur.ScoreA < cur.ScoreB) _aWasBehind = true;
            if (cur.ScoreB < cur.ScoreA) _bWasBehind = true;
        }

        if (ctx is not null) await EmitMira(ctx);
    }

    private (int, int?)? ComputeChampion(int? activeTid)
    {
        if (activeTid is null || _current is not null) return null;
        var tm = _matches.Where(m => m.TournamentId == activeTid).ToList();
        if (tm.Count == 0 || tm.Any(m => m.Status != MatchStatus.Finished)) return null;

        var bracket = tm.Where(m => m.GroupName is null && m.Round is not null).ToList();
        if (bracket.Count > 0)
        {
            var final = bracket.OrderByDescending(m => m.Round).First();
            if (final.TeamAId is null || final.TeamBId is null || final.ScoreA == final.ScoreB) return null;
            var aWins = final.ScoreA > final.ScoreB;
            return (aWins ? final.TeamAId!.Value : final.TeamBId!.Value, aWins ? final.TeamBId : final.TeamAId);
        }
        if (_currentTournament?.Format == TournamentFormat.RoundRobin)
        {
            var rows = _standings?.Groups.FirstOrDefault()?.Rows ?? [];
            if (rows.Count >= 3) return (rows[0].TeamId, rows.Count > 1 ? rows[1].TeamId : null);
        }
        return null;
    }

    private void DetectGoal(Match? current)
    {
        if (current is null) { _prevScore = null; return; }
        if (_prevScore is { } p && p.Id == current.Id)
        {
            if (current.ScoreA > p.A) TriggerGoal("a");
            else if (current.ScoreB > p.B) TriggerGoal("b");
        }
        _prevScore = (current.Id, current.ScoreA, current.ScoreB);
    }

    private void TriggerGoal(string side)
    {
        _goalSide = side; _goalKey++;
        _goalClear?.Dispose();
        _goalClear = new System.Threading.Timer(_ => InvokeAsync(() => { _goalSide = null; StateHasChanged(); }), null, 1800, System.Threading.Timeout.Infinite);
    }

    private string Name(int? id) => id is { } i && _names.TryGetValue(i, out var n) ? n : "—";

    /// <summary>Verbleibende Sekunden der laufenden Halbzeit (null, wenn kein Spiel läuft).</summary>
    private int? CurrentRemainingSec()
    {
        if (_current is not { } m) return null;
        var half = _currentTournament?.HalfDurationSec ?? 360;
        return (int)Math.Ceiling(MatchClock.RemainingSeconds(
            new ClockState(m.ElapsedSec, m.TimerRunning, m.TimerStartedAtMs), half, MatchControl.NowMs()));
    }

    /// <summary>
    /// Prüft zeitbezogene MIRA-Anlässe des laufenden Spiels: Golden Goal (Zeit abgelaufen +
    /// K.o.-Gleichstand), Schlussphase (letzte Minute) und periodische Zwischenkommentare.
    /// Jeder Anlass feuert höchstens einmal (Entprellung über Zustandsfelder).
    /// </summary>
    private MiraContext? DetectTimeContext()
    {
        if (_current is not { TimerRunning: true } m) return null;

        // Zustand bei Spielwechsel zurücksetzen.
        if (_timeMatchId != m.Id)
        {
            _timeMatchId = m.Id;
            _finalMinuteHalf = 0;
            _goldenGoalAnnounced = false;
            _timeUpAnnounced = false;
            _lastInterludeMs = MatchControl.NowMs();
        }

        var remaining = CurrentRemainingSec() ?? 0;
        var tied = m.ScoreA == m.ScoreB;
        var isKo = _currentTournament?.Format == TournamentFormat.Knockout
            || (_currentTournament?.Format == TournamentFormat.Groups && m.GroupName is null);
        var a = Name(m.TeamAId);
        var b = Name(m.TeamBId);

        // Golden Goal: reguläre Zeit abgelaufen, K.o.-Spiel, Gleichstand – einmalig.
        if (remaining <= 0 && isKo && tied && !_goldenGoalAnnounced)
        {
            _goldenGoalAnnounced = true;
            return new MiraContext { Mood = MiraMood.GoldenGoal, TeamA = a, TeamB = b, ScoreA = m.ScoreA, ScoreB = m.ScoreB };
        }

        // Reguläre Spielzeit der letzten Halbzeit abgelaufen → kurze Zusammenfassung (einmalig).
        // Beim K.o.-Gleichstand übernimmt stattdessen der Golden Goal (Spiel läuft weiter).
        var halves = _currentTournament?.Halves ?? 1;
        if (remaining <= 0 && !(isKo && tied) && !_timeUpAnnounced && m.CurrentHalf >= halves)
        {
            _timeUpAnnounced = true;
            return new MiraContext { Mood = MiraMood.TimeUp, TeamA = a, TeamB = b, ScoreA = m.ScoreA, ScoreB = m.ScoreB };
        }

        // Schlussphase: letzte Minute – einmal je Halbzeit.
        if (remaining is > 0 and <= 60 && _finalMinuteHalf != m.CurrentHalf)
        {
            _finalMinuteHalf = m.CurrentHalf;
            return new MiraContext { Mood = MiraMood.FinalMinute, TeamA = a, TeamB = b, ScoreA = m.ScoreA, ScoreB = m.ScoreB, RemainingSec = remaining };
        }

        // Periodischer Zwischenkommentar (alle 2 Min), nicht in der Schlussminute.
        var now = MatchControl.NowMs();
        if (remaining > 65 && now - _lastInterludeMs >= _interludeIntervalMs)
        {
            _lastInterludeMs = now;
            return new MiraContext { Mood = MiraMood.Interlude, TeamA = a, TeamB = b, ScoreA = m.ScoreA, ScoreB = m.ScoreB, RemainingSec = remaining };
        }

        return null;
    }

    /// <summary>Reichert den Kontext um Zeit + Turnier-/Tabellenkontext an und holt den MIRA-Spruch (Overlap-geschützt).</summary>
    private async Task EmitMira(MiraContext ctx)
    {
        if (_miraBusy) return;
        _miraBusy = true;
        try
        {
            var enriched = ctx with
            {
                Situation = BuildSituation(),
                RemainingSec = ctx.RemainingSec ?? CurrentRemainingSec(),
                Half = _current?.CurrentHalf,
                Halves = _currentTournament?.Halves,
            };
            _miraText = await Mira.CommentAsync(enriched);
            await InvokeAsync(StateHasChanged);
        }
        // Nach JEDEM Kommentar (Tor, Anpfiff, Schlussphase …) die Interlude-Uhr neu starten,
        // damit direkt nach einem Ereignis kein Zwischenkommentar hinterherfeuert.
        finally { _miraBusy = false; _lastInterludeMs = MatchControl.NowMs(); }
    }

    /// <summary>
    /// Erkennt einmalig, dass die K.o.-Phase eines Gruppen-Turniers gerade frisch entstanden ist
    /// (alle Gruppenspiele beendet, Baum vorhanden, noch kein K.o.-Spiel gestartet) – für die
    /// MIRA-Ansage des Übergangs Gruppenphase → K.o.
    /// </summary>
    private MiraContext? DetectKnockoutStart()
    {
        if (_activeTid is not { } tid || _currentTournament?.Format != TournamentFormat.Groups) return null;
        if (_koAnnouncedTid == tid) return null;

        var tm = _matches.Where(m => m.TournamentId == tid).ToList();
        var group = tm.Where(m => m.GroupName is not null).ToList();
        var ko = tm.Where(m => m.GroupName is null).ToList();
        if (group.Count == 0 || ko.Count == 0) return null;                // noch kein K.o.-Baum
        if (group.Any(m => m.Status != MatchStatus.Finished)) return null;  // Gruppen noch nicht fertig
        if (ko.Any(m => m.Status != MatchStatus.Scheduled)) return null;    // K.o. läuft bereits → nicht (neu) ansagen

        _koAnnouncedTid = tid;
        return new MiraContext { Mood = MiraMood.KnockoutStart };
    }

    /// <summary>Kompakter Turnier-/Tabellenkontext für MIRA Stufe B (Stand, letzte Ergebnisse, offene Spiele).</summary>
    private string? BuildSituation()
    {
        if (_activeTid is not { } tid) return null;
        var tm = _matches.Where(m => m.TournamentId == tid).ToList();
        if (tm.Count == 0) return null;

        var sb = new System.Text.StringBuilder();
        var fmtLabel = _currentTournament?.Format switch
        {
            TournamentFormat.Knockout => "K.o.-System",
            TournamentFormat.Groups => "Gruppenphase + K.o.",
            _ => "Liga (jeder gegen jeden)",
        };
        sb.AppendLine($"Turnier \"{_currentTournament?.Name}\", Format: {fmtLabel}.");

        var groups = _standings?.Groups.Where(g => g.Rows.Count > 0).ToList() ?? [];
        foreach (var g in groups)
        {
            sb.AppendLine(g.GroupName is null ? "Tabelle:" : $"Gruppe {g.GroupName}:");
            var rank = 1;
            foreach (var row in g.Rows)
            {
                var diff = row.GoalDiff > 0 ? $"+{row.GoalDiff}" : row.GoalDiff.ToString();
                sb.AppendLine($"  {rank}. {Name(row.TeamId)} – {row.Points} Pkt, {row.GoalsFor}:{row.GoalsAgainst} Tore ({diff}), {row.Played} Sp.");
                rank++;
            }
        }
        if (groups.Count > 0)
            sb.AppendLine("(Ein laufendes Spiel ist im Zwischenstand bereits eingerechnet.)");

        // Duell-Historie der aktuell relevanten Paarung (laufendes bzw. nächstes Spiel),
        // turnierübergreifend – gut für Anpfiff-Begrüßung und Zwischenkommentare.
        var focus = _current ?? _next;
        if (focus is { TeamAId: { } fa, TeamBId: { } fb })
        {
            var duels = _matches.Where(m => m.Status == MatchStatus.Finished && m.Id != focus.Id
                    && ((m.TeamAId == fa && m.TeamBId == fb) || (m.TeamAId == fb && m.TeamBId == fa)))
                .OrderByDescending(m => m.FinishedAt).ThenByDescending(m => m.Id).ToList();
            if (duels.Count > 0)
            {
                int winA = 0, winB = 0, drawn = 0;
                foreach (var d in duels)
                {
                    var ga = d.TeamAId == fa ? d.ScoreA : d.ScoreB; // Tore von Team fa
                    var gb = d.TeamAId == fa ? d.ScoreB : d.ScoreA; // Tore von Team fb
                    if (ga > gb) winA++; else if (gb > ga) winB++; else drawn++;
                }
                sb.AppendLine($"Direkte Duelle {Name(fa)} vs. {Name(fb)}: {winA} Siege {Name(fa)}, {winB} Siege {Name(fb)}, {drawn} Remis (aus {duels.Count} Spielen).");
                var last = duels[0];
                sb.AppendLine($"  Letztes Duell: {Name(last.TeamAId)} {last.ScoreA}:{last.ScoreB} {Name(last.TeamBId)}.");
            }
            else
            {
                sb.AppendLine($"Direkte Duelle {Name(fa)} vs. {Name(fb)}: noch nie gegeneinander gespielt – Premiere!");
            }
        }

        // K.o.-Baum (falls vorhanden): Runden + Paarungen, damit MIRA Wege und mögliche
        // Finalpaarungen beschreiben kann. „(noch offen)" = Sieger steht noch nicht fest.
        var bracket = tm.Where(m => m.GroupName is null && m.Round is not null)
            .OrderBy(m => m.Round).ThenBy(m => m.Id).ToList();
        if (bracket.Count > 0)
        {
            string SlotName(int? id) => id is null ? "(noch offen)" : Name(id);
            sb.AppendLine("K.o.-Baum:");
            foreach (var rg in bracket.GroupBy(m => m.Round!.Value).OrderBy(g => g.Key))
            {
                sb.AppendLine($"  {RoundLabel(rg.Key, bracket)}:");
                foreach (var km in rg.OrderBy(m => m.Id))
                    sb.AppendLine($"    {SlotName(km.TeamAId)} vs. {SlotName(km.TeamBId)}");
            }
        }

        var recent = tm.Where(m => m.Status == MatchStatus.Finished)
            .OrderByDescending(m => m.FinishedAt).ThenByDescending(m => m.Id).Take(3).ToList();
        if (recent.Count > 0)
        {
            sb.AppendLine("Letzte Ergebnisse:");
            foreach (var m in recent)
                sb.AppendLine($"  {Name(m.TeamAId)} {m.ScoreA}:{m.ScoreB} {Name(m.TeamBId)}");
        }

        var open = tm.Where(m => m.Status == MatchStatus.Scheduled && m.TeamAId is not null && m.TeamBId is not null)
            .OrderBy(m => m.Round ?? 0).ThenBy(m => m.Id).Take(4).ToList();
        if (open.Count > 0)
        {
            sb.AppendLine("Noch ausstehend:");
            foreach (var m in open)
                sb.AppendLine($"  {Name(m.TeamAId)} vs. {Name(m.TeamBId)}");
        }

        return sb.ToString().TrimEnd();
    }

    /// <summary>Gliedert den Spielplan: Gruppen → je Gruppe (+ K.o.), K.o. → je Runde, Liga → flach.</summary>
    private List<(string? Header, List<Match> Rows)> BuildPlan(List<Match> plan)
    {
        var sections = new List<(string?, List<Match>)>();
        var fmt = _currentTournament?.Format;

        if (fmt == TournamentFormat.Groups)
        {
            foreach (var g in plan.Where(m => m.GroupName != null).GroupBy(m => m.GroupName!).OrderBy(g => g.Key))
                sections.Add(($"Gruppe {g.Key}", g.OrderBy(m => m.Id).ToList()));
            var ko = plan.Where(m => m.GroupName == null).OrderBy(m => m.Round).ThenBy(m => m.Id).ToList();
            if (ko.Count > 0)
                foreach (var r in ko.GroupBy(m => m.Round ?? 0).OrderBy(g => g.Key))
                    sections.Add((RoundLabel(r.Key, ko), r.OrderBy(m => m.Id).ToList()));
        }
        else if (fmt == TournamentFormat.Knockout)
        {
            foreach (var r in plan.GroupBy(m => m.Round ?? 0).OrderBy(g => g.Key))
                sections.Add((RoundLabel(r.Key, plan), r.OrderBy(m => m.Id).ToList()));
        }
        else
        {
            sections.Add((null, plan.OrderBy(m => m.Round ?? 0).ThenBy(m => m.Id).ToList()));
        }
        return sections;
    }

    /// <summary>Runden-Beschriftung im K.o. (Finale/Halbfinale/Viertelfinale, sonst „Runde N").</summary>
    private static string RoundLabel(int round, List<Match> bracket)
    {
        var max = bracket.Count > 0 ? bracket.Max(m => m.Round ?? 0) : round;
        return (max - round) switch
        {
            0 => "Finale",
            1 => "Halbfinale",
            2 => "Viertelfinale",
            _ => $"Runde {round}",
        };
    }

    private static string FormatClock(double totalSec)
    {
        var s = Math.Max(0, (int)Math.Ceiling(totalSec));
        return $"{s / 60:00}:{s % 60:00}";
    }

    public void Dispose()
    {
        Notifier.Changed -= OnChanged;
        _clock?.Dispose();
        _goalClear?.Dispose();
    }
}
