<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!--
    Nur der öffentliche nuget.org-Feed. Die global konfigurierten, privaten
    A+W-Azure-DevOps-Feeds werden hier bewusst ausgeschlossen (sie erfordern
    Auth und liefern sonst 401 beim Paket-Restore).
  -->
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
</configuration>
